<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.dykj.domain.chat.repository.ChatRepository">

    <insert id="insertMessage" parameterType="com.project.dykj.domain.chat.dto.ChatMessageVO">
        INSERT INTO CHAT_MESSAGES (
            CHAT_ID, 
            USER_ID, 
            CHAT_CONTENT, 
            SEND_TIME
        ) VALUES (
            SEQ_CHAT_ID.NEXTVAL, 
            #{userId}, 
            #{chatContent}, 
            SYSDATE
        )
    </insert>

</mapper>